<group name="cowrie,">

  <rule id="100002" level="0">
    <decoded_as>json</decoded_as>
    <field name="eventid">cowrie.*</field>
    <description>Cowrie event detected</description>
  </rule>

  <rule id="100003" level="5">
    <if_sid>100002</if_sid>
    <field name="eventid">cowrie.login.success</field>
    <description>Cowrie successful login</description>
    <group>authentication_success,pci_dss_10.2.5</group>
  </rule>

  <rule id="100004" level="7">
    <if_sid>100002</if_sid>
    <field name="eventid">cowrie.command.input</field>
    <description>Cowrie command execution detected</description>
  </rule>

  <rule id="100005" level="12">
    <if_sid>100002</if_sid>
    <field name="eventid">cowrie.session.file_download</field>
    <description>Malware payload download detected</description>
  </rule>

</group>
